# ads-dashboard local environment template
#
# Usage:
#   1) cp .env.example .env
#   2) Fill in values in .env (NEVER commit .env — it's gitignored)
#   3) Run:  set -a && source .env && set +a && ./gradlew bootRun
#
# You only need to fill in the platforms/accounts you actually want to test.
# Unfilled vars stay empty and those endpoints just return empty results.

# === Dashboard Login (Google OAuth) ===
# Create a Web application OAuth client in GCP and add this redirect URI:
#   http://localhost:8080/login/oauth2/code/google
# Only users whose email ends with @ALLOWED_EMAIL_DOMAIN can sign in.
DASHBOARD_OAUTH_CLIENT_ID=
DASHBOARD_OAUTH_CLIENT_SECRET=
ALLOWED_EMAIL_DOMAIN=caring.co.kr

# === Meta Marketing API ===
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_API_VERSION=v21.0

# === Google Ads API ===
# CUSTOMER_ID: 10-digit account ID with hyphens removed (e.g. 1234567890).
# LOGIN_CUSTOMER_ID: MCC ID only if you access the customer THROUGH a manager
#   account. Leave empty if the OAuth user has direct access to CUSTOMER_ID.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_API_VERSION=v20

# === Naver Search Ads (up to 7 accounts) ===
# Start with just account 0 to verify the pipeline works, then add 1..6.
NAVER_ADS_0_NAME=caring_official
NAVER_ADS_0_API_KEY=
NAVER_ADS_0_SECRET_KEY=
NAVER_ADS_0_CUSTOMER_ID=

NAVER_ADS_1_NAME=
NAVER_ADS_1_API_KEY=
NAVER_ADS_1_SECRET_KEY=
NAVER_ADS_1_CUSTOMER_ID=

NAVER_ADS_2_NAME=
NAVER_ADS_2_API_KEY=
NAVER_ADS_2_SECRET_KEY=
NAVER_ADS_2_CUSTOMER_ID=

NAVER_ADS_3_NAME=
NAVER_ADS_3_API_KEY=
NAVER_ADS_3_SECRET_KEY=
NAVER_ADS_3_CUSTOMER_ID=

NAVER_ADS_4_NAME=
NAVER_ADS_4_API_KEY=
NAVER_ADS_4_SECRET_KEY=
NAVER_ADS_4_CUSTOMER_ID=

NAVER_ADS_5_NAME=
NAVER_ADS_5_API_KEY=
NAVER_ADS_5_SECRET_KEY=
NAVER_ADS_5_CUSTOMER_ID=

NAVER_ADS_6_NAME=
NAVER_ADS_6_API_KEY=
NAVER_ADS_6_SECRET_KEY=
NAVER_ADS_6_CUSTOMER_ID=
